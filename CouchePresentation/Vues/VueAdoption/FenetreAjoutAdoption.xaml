<Window x:Class="Accardi_Alessandro_Refuge_WPF.Vues.FenetreAjoutAdoption"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Accardi_Alessandro_Refuge_WPF.Vues"
        Title="Ajouter une adoption" Height="500" Width="600">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Animal concerné -->
        <TextBlock Grid.Row="0" Margin="5" FontWeight="Bold" FontSize="16">
            <TextBlock.Text>
                <Binding Path="Animal.Nom" StringFormat="Adoption pour : {0}" />
            </TextBlock.Text>
        </TextBlock>

        <!-- Liste des contacts -->
        <DataGrid Grid.Row="1"
                  Name="DgContacts"
                  Margin="5"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  ItemsSource="{Binding Contacts}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom"     Binding="{Binding Nom}"     Width="120" />
                <DataGridTextColumn Header="Prénom"  Binding="{Binding Prenom}"  Width="120" />
                <DataGridTextColumn Header="GSM"     Binding="{Binding Gsm}"     Width="110" />
                <DataGridTextColumn Header="Email"   Binding="{Binding Email}"   Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Statut -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="5">
            <TextBlock Text="Statut :"
                       VerticalAlignment="Center"
                       Width="120" />
            <ComboBox ItemsSource="{Binding Statuts}"
                      SelectedItem="{Binding StatutSelectionne}"
                      Width="150" />
        </StackPanel>

        <!-- Date de demande -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="5">
            <TextBlock Text="Date de demande :"
                       VerticalAlignment="Center"
                       Width="120" />
            <DatePicker SelectedDate="{Binding DateDemande}"
                        DisplayDateStart="{Binding DateDemandeMin, Mode=OneWay}"
                        DisplayDateEnd="{Binding DateDemandeMax, Mode=OneWay}"
                        Width="150" />
        </StackPanel>

        <!-- Boutons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="5">
            <Button Content="Enregistrer" Width="90" Margin="5"
                    Click="BtnEnregistrer_Click" />
            <Button Content="Annuler" Width="90" Margin="5"
                    Click="BtnAnnuler_Click" />
        </StackPanel>

    </Grid>
</Window>