<Window x:Class="Accardi_Alessandro_Refuge_WPF.Vues.FenetreModifierAnimal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Accardi_Alessandro_Refuge_WPF.Vues"
        mc:Ignorable="d"
        Title="FenetreModifierAnimal" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*"   />
        </Grid.ColumnDefinitions>

        <!-- Nom en lecture seule -->
        <TextBlock Text="Nom :"
                   Grid.Row="0" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Animal.Nom}"
                   Grid.Row="0" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5"
                   FontWeight="Bold" />

        <!-- Stérilisé -->
        <TextBlock Text="Stérilisé :"
                   Grid.Row="1" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <ComboBox  Name="CbSterilise"
                   Grid.Row="1" Grid.Column="1" Margin="5"
                   ItemsSource="{Binding Sterilises}"
                   SelectedItem="{Binding Animal.Sterilise}" />

        <!-- Date de stérilisation -->
        <TextBlock Text="Date de stérilisation :"
                   Grid.Row="2" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <DatePicker Name="DpDateSterilisation"
                    Grid.Row="2" Grid.Column="1" Margin="5"
                    SelectedDate="{Binding Animal.DateDeSterilisation}" />

        <!-- Date de décès -->
        <TextBlock Text="Date de décès :"
                   Grid.Row="3" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <DatePicker Name="DpDateDeces"
                    Grid.Row="3" Grid.Column="1" Margin="5"
                    SelectedDate="{Binding Animal.DateDeDeces}" />

        <!-- Particularités -->
        <TextBlock Text="Particularités :"
                   Grid.Row="4" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBox   Name="TbParticularites"
                   Grid.Row="4" Grid.Column="1" Margin="5"
                   Text="{Binding Animal.Particularite}" />

        <!-- Description -->
        <TextBlock Text="Description :"
                   Grid.Row="5" Grid.Column="0"
                   VerticalAlignment="Top" Margin="5" />
        <TextBox   Name="TbDescription"
                   Grid.Row="5" Grid.Column="1" Margin="5"
                   Height="60"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto"
                   Text="{Binding Animal.Description}" />

        <!-- Boutons -->
        <StackPanel Grid.Row="6" Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="5">
            <Button Content="Enregistrer" Width="90" Margin="5"
                    Click="BtnEnregistrer_Click" />
            <Button Content="Annuler"     Width="90" Margin="5"
                    Click="BtnAnnuler_Click" />
        </StackPanel>

    </Grid>
</Window>
