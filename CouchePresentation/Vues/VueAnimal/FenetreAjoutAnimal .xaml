<Window x:Class="Accardi_Alessandro_Refuge_WPF.Vues.FenetreAjoutAnimal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Accardi_Alessandro_Refuge_WPF.Vues"
        mc:Ignorable="d"
        Title="FenetreAjoutAnimal" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*"   />
        </Grid.ColumnDefinitions>

        <!-- Nom -->
        <TextBlock Text="Nom :"
                   Grid.Row="0" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBox   Name="TbNom"
                   Grid.Row="0" Grid.Column="1" Margin="5" />

        <!-- Type -->
        <TextBlock Text="Type :"
                   Grid.Row="1" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <ComboBox  Name="CbType"
                   Grid.Row="1" Grid.Column="1" Margin="5"
                   ItemsSource="{Binding Types}" />

        <!-- Sexe -->
        <TextBlock Text="Sexe :"
                   Grid.Row="2" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <ComboBox  Name="CbSexe"
                   Grid.Row="2" Grid.Column="1" Margin="5"
                   ItemsSource="{Binding Sexes}" />

        <!-- Stérilisé -->
        <TextBlock Text="Stérilisé :"
                   Grid.Row="3" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <ComboBox  Name="CbSterilise"
                   Grid.Row="3" Grid.Column="1" Margin="5"
                   ItemsSource="{Binding Sterilises}" />

        <!-- Date de naissance -->
        <TextBlock Text="Date de naissance :"
                   Grid.Row="4" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <DatePicker Name="DpDateNaissance"
                    Grid.Row="4" Grid.Column="1" Margin="5" />

        <!-- Date de stérilisation -->
        <TextBlock Text="Date de stérilisation :"
                   Grid.Row="5" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <DatePicker Name="DpDateSterilisation"
                    Grid.Row="5" Grid.Column="1" Margin="5" />

        <!-- Particularités -->
        <TextBlock Text="Particularités :"
                   Grid.Row="6" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBox   Name="TbParticularites"
                   Grid.Row="6" Grid.Column="1" Margin="5" />

        <!-- Description -->
        <TextBlock Text="Description :"
                   Grid.Row="7" Grid.Column="0"
                   VerticalAlignment="Top" Margin="5" />
        <TextBox   Name="TbDescription"
                   Grid.Row="7" Grid.Column="1" Margin="5"
                   Height="60"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto" />

        <!-- Couleurs -->
        <TextBlock Text="Couleurs :"
                   Grid.Row="8" Grid.Column="0"
                   VerticalAlignment="Top" Margin="5" />
        <ListBox   Name="LbCouleurs"
                   Grid.Row="8" Grid.Column="1" Margin="5"
                   Height="80"
                   ItemsSource="{Binding Couleurs}"
                   DisplayMemberPath="Nom"
                   SelectionMode="Multiple" />

        <!-- Compatibilités -->
        <TextBlock Text="Compatibilités :"
                   Grid.Row="9" Grid.Column="0"
                   VerticalAlignment="Top" Margin="5" />
        <ItemsControl Grid.Row="9" Grid.Column="1"
                      ItemsSource="{Binding Compatibilites}"
                      Margin="5">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox IsChecked="{Binding Selectionnee}"
                                  Width="20" />
                        <TextBlock Text="{Binding Compatibilite.Type}"
                                   Width="180"
                                   VerticalAlignment="Center" />
                        <CheckBox Content="Incompatible"
                                  IsChecked="{Binding Incompatible}" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Date d'entrée -->
        <TextBlock Text="Date d'entrée :"
                   Grid.Row="10" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <DatePicker Name="DpDateEntree"
                    Grid.Row="10" Grid.Column="1" Margin="5"
                    DisplayDateStart="{Binding DateEntreeMin, Mode=OneWay}"
                    DisplayDateEnd="{Binding DateEntreeMax, Mode=OneWay}"
                    SelectedDate="{Binding DateEntree}" />

        <!-- Raison -->
        <TextBlock Text="Raison d'entrée :"
                   Grid.Row="11" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <ComboBox  Name="CbRaison"
                   Grid.Row="11" Grid.Column="1" Margin="5"
                   ItemsSource="{Binding Raisons}" />

        <!-- Contact -->
        <TextBlock Text="Contact :"
                   Grid.Row="12" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <ComboBox  Name="CbContact"
                   Grid.Row="12" Grid.Column="1" Margin="5"
                   ItemsSource="{Binding Contacts}"
                   DisplayMemberPath="Nom"
                   SelectedItem="{Binding ContactSelectionne}" />

        <!-- Boutons -->
        <StackPanel Grid.Row="13" Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="5">
            <Button Content="Enregistrer" Width="90" Margin="5"
                    Click="BtnEnregistrer_Click" />
            <Button Content="Annuler"     Width="90" Margin="5"
                    Click="BtnAnnuler_Click" />
        </StackPanel>

    </Grid>
</Window>
