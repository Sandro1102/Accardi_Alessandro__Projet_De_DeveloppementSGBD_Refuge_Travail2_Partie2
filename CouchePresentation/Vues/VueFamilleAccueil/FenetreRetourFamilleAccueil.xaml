<Window x:Class="Accardi_Alessandro_Refuge_WPF.Vues.FenetreRetourFamilleAccueil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Accardi_Alessandro_Refuge_WPF.Vues"
        Title="Retour de famille d'accueil" Height="350" Width="500">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Animal concerné -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="{Binding Animal.Nom, StringFormat='Retour de famille d\'accueil pour : {0}'}"
                   FontWeight="Bold"
                   FontSize="16"
                   Margin="5" />

        <!-- Contact -->
        <TextBlock Text="Famille d'accueil :"
                   Grid.Row="1" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding FaActive.ContactConcerne.Nom}"
                   Grid.Row="1" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5" />

        <!-- Date de départ -->
        <TextBlock Text="Date de départ :"
                   Grid.Row="2" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding FaActive.Date, StringFormat=dd/MM/yyyy}"
                   Grid.Row="2" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5" />

        <!-- Date de retour -->
        <TextBlock Text="Date de retour :"
                   Grid.Row="3" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="Aujourd'hui"
                   Grid.Row="3" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5"
                   FontWeight="Bold" />

        <!-- Boutons -->
        <StackPanel Grid.Row="5" Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="5">
            <Button Content="Confirmer le retour" Width="140" Margin="5"
                    Click="BtnConfirmer_Click" />
            <Button Content="Annuler" Width="90" Margin="5"
                    Click="BtnAnnuler_Click" />
        </StackPanel>

    </Grid>
</Window>