<Window x:Class="Accardi_Alessandro_Refuge_WPF.Vues.FenetreListerFamillesParAnimal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Accardi_Alessandro_Refuge_WPF.Vues"
        Title="Familles d'accueil de l'animal" Height="500" Width="600">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Animal concerné -->
        <TextBlock Grid.Row="0" Margin="5" FontWeight="Bold" FontSize="16">
            <TextBlock.Text>
                <Binding Path="Animal.Nom" StringFormat="Familles d'accueil de : {0}" />
            </TextBlock.Text>
        </TextBlock>

        <!-- Liste des familles d'accueil -->
        <DataGrid Grid.Row="1"
                  Margin="5"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Familles}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Famille"      Binding="{Binding ContactConcerne.Nom}"                          Width="120" />
                <DataGridTextColumn Header="Prénom"       Binding="{Binding ContactConcerne.Prenom}"                       Width="120" />
                <DataGridTextColumn Header="Date départ"  Binding="{Binding Date, StringFormat=dd/MM/yyyy}"                Width="100" />
                <DataGridTextColumn Header="Date retour"  Binding="{Binding DateFin, StringFormat=dd/MM/yyyy}"             Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bouton retour -->
        <Button Grid.Row="2"
                Content="Retour"
                Width="80"
                Margin="5"
                HorizontalAlignment="Right"
                Click="BtnRetour_Click" />

    </Grid>
</Window>