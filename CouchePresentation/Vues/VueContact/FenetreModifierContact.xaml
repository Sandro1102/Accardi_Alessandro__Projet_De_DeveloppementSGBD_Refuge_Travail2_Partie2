<Window x:Class="Accardi_Alessandro_Refuge_WPF.Vues.FenetreModifierContact"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Accardi_Alessandro_Refuge_WPF.Vues"
        Title="Modifier un contact" Height="400" Width="600">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Nom en lecture seule -->
        <TextBlock Text="Nom :"
                   Grid.Row="0" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.Nom}"
                   Grid.Row="0" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5"
                   FontWeight="Bold" />

        <!-- Prénom en lecture seule -->
        <TextBlock Text="Prénom :"
                   Grid.Row="1" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.Prenom}"
                   Grid.Row="1" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5"
                   FontWeight="Bold" />

        <!-- Rue -->
        <TextBlock Text="Rue :"
                   Grid.Row="2" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBox   Name="TbRue"
                   Grid.Row="2" Grid.Column="1" Margin="5"
                   Text="{Binding Contact.Rue}" />

        <!-- Code postal -->
        <TextBlock Text="Code postal :"
                   Grid.Row="3" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBox   Name="TbCp"
                   Grid.Row="3" Grid.Column="1" Margin="5"
                   Text="{Binding Contact.Cp}" />

        <!-- Localité -->
        <TextBlock Text="Localité :"
                   Grid.Row="4" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBox   Name="TbLocalite"
                   Grid.Row="4" Grid.Column="1" Margin="5"
                   Text="{Binding Contact.Localite}" />

        <!-- GSM -->
        <TextBlock Text="GSM :"
                   Grid.Row="5" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBox   Name="TbGsm"
                   Grid.Row="5" Grid.Column="1" Margin="5"
                   Text="{Binding Contact.Gsm}" />

        <!-- Téléphone fixe -->
        <TextBlock Text="Téléphone fixe :"
                   Grid.Row="6" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBox   Name="TbTelephone"
                   Grid.Row="6" Grid.Column="1" Margin="5"
                   Text="{Binding Contact.Telephone}" />

        <!-- Email -->
        <TextBlock Text="Email :"
                   Grid.Row="7" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBox   Name="TbEmail"
                   Grid.Row="7" Grid.Column="1" Margin="5"
                   Text="{Binding Contact.Email}" />

        <!-- Boutons -->
        <StackPanel Grid.Row="8" Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="5">
            <Button Content="Enregistrer" Width="90" Margin="5"
                    Click="BtnEnregistrer_Click" />
            <Button Content="Annuler" Width="90" Margin="5"
                    Click="BtnAnnuler_Click" />
        </StackPanel>

    </Grid>
</Window>