<Window x:Class="Accardi_Alessandro_Refuge_WPF.Vues.FenetreConsulterContact"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Accardi_Alessandro_Refuge_WPF.Vues"
        Title="Consulter un contact" Height="500" Width="600">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Nom -->
        <TextBlock Text="Nom :"
                   Grid.Row="0" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.Nom}"
                   Grid.Row="0" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5"
                   FontWeight="Bold" />

        <!-- Prénom -->
        <TextBlock Text="Prénom :"
                   Grid.Row="1" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.Prenom}"
                   Grid.Row="1" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5" />

        <!-- Registre national -->
        <TextBlock Text="Registre national :"
                   Grid.Row="2" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.RegistreNational}"
                   Grid.Row="2" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5" />

        <!-- Rue -->
        <TextBlock Text="Rue :"
                   Grid.Row="3" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.Rue}"
                   Grid.Row="3" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5" />

        <!-- Code postal -->
        <TextBlock Text="Code postal :"
                   Grid.Row="4" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.Cp}"
                   Grid.Row="4" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5" />

        <!-- Localité -->
        <TextBlock Text="Localité :"
                   Grid.Row="5" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.Localite}"
                   Grid.Row="5" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5" />

        <!-- GSM -->
        <TextBlock Text="GSM :"
                   Grid.Row="6" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.Gsm}"
                   Grid.Row="6" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5" />

        <!-- Téléphone fixe -->
        <TextBlock Text="Téléphone fixe :"
                   Grid.Row="7" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.Telephone}"
                   Grid.Row="7" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5" />

        <!-- Email -->
        <TextBlock Text="Email :"
                   Grid.Row="8" Grid.Column="0"
                   VerticalAlignment="Center" Margin="5" />
        <TextBlock Text="{Binding Contact.Email}"
                   Grid.Row="8" Grid.Column="1"
                   VerticalAlignment="Center" Margin="5" />

        <!-- Rôles -->
        <TextBlock Text="Rôles :"
                   Grid.Row="9" Grid.Column="0"
                   VerticalAlignment="Top" Margin="5" />
        <ScrollViewer Grid.Row="9" Grid.Column="1"
                      MaxHeight="80"
                      VerticalScrollBarVisibility="Auto"
                      Margin="5">
            <ItemsControl ItemsSource="{Binding Roles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Margin="0,2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bouton retour -->
        <Button Grid.Row="10" Grid.Column="1"
                Content="Retour"
                Width="80"
                Margin="5"
                HorizontalAlignment="Right"
                Click="BtnRetour_Click" />

    </Grid>
</Window>