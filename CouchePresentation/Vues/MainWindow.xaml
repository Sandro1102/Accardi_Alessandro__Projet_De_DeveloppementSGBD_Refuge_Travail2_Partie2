<Window x:Class="Accardi_Alessandro_Refuge_WPF.Vues.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Refuge Animalier" Height="600" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="Animal">
                <MenuItem Header="Ajouter un animal"
                          Click="AjouterAnimal_Click" />
                <MenuItem Header="Modifier un animal" 
                          Click="ModifierAnimal_Click"/>
                <MenuItem Header="Supprimer un animal" 
                          Click="SupprimerAnimal_Click" />
                <MenuItem Header="Lister les animaux du refuge"
                          Click="ListerAnimaux_Click" />
            </MenuItem>
            <MenuItem Header="Contact">
                <MenuItem Header="Ajouter une personne de contact"
                          Click="AjouterContact_Click" />
                <MenuItem Header="Modifier les coordonnées"
                          Click="ModifierContact_Click" />
                <MenuItem Header="Supprimer une personne de contact"
                          Click="SupprimerContact_Click" />
                <MenuItem Header="Consulter une personne de contact"
                          Click="ListerContacts_Click" />
            </MenuItem>
            <MenuItem Header="Famille d'accueil">
                <MenuItem Header="Ajouter une famille d'accueil" />
                <MenuItem Header="Enregistrer le départ d'un animal" />
                <MenuItem Header="Enregistrer le retour d'un animal" />
                <MenuItem Header="Lister les familles par animal" />
                <MenuItem Header="Lister les animaux par famille" />
            </MenuItem>
            <MenuItem Header="Adoption">
                <MenuItem Header="Ajouter une adoption" />
                <MenuItem Header="Lister les adoptions et statuts" />
                <MenuItem Header="Modifier le statut d'une adoption" />
            </MenuItem>
            <MenuItem Header="Vaccin">
                <MenuItem Header="Ajouter un vaccin" />
                <MenuItem Header="Supprimer un vaccin" />
            </MenuItem>
        </Menu>

        <!-- Zone contenu -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                  VerticalScrollBarVisibility="Auto"
                  Margin="5">
                <ContentControl Name="ZoneContenu" />
            </ScrollViewer>

            <DataGrid Grid.Row="0"
                      Name="dgListe"
                      Margin="5"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Visibility="Collapsed"
                      MouseDoubleClick="DgListe_DoubleClick" />

            <Button Grid.Row="1"
            Name="BtnRetour"
            Content="Retour"
            Width="80"
            Margin="5"
            HorizontalAlignment="Right"
            Visibility="Collapsed"
            Click="BtnRetour_Click" />
        </Grid>

    </Grid>
</Window>